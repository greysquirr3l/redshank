# Copy to .env in your workspace (or export into your shell environment).
# Redshank resolves credentials in this priority order:
#   REDSHANK_<KEY>  (app-namespaced — use when running multiple agents)
#   OPENPLANTER_<KEY>  (legacy backward compat)
#   <KEY>  (bare/global env var — sufficient for most users)
# All variables are optional; only set what your investigation needs.

# ── LLM providers ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...
CEREBRAS_API_KEY=...

# Ollama — base URL of your local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# ── Search / enrichment ──────────────────────────────────────
EXA_API_KEY=...
VOYAGE_API_KEY=...

# ── OSINT / data sources ─────────────────────────────────────
HIBP_API_KEY=...
GITHUB_TOKEN=ghp_...
FEC_API_KEY=...
OPENCORPORATES_API_KEY=...
